generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ReviewCycleType {
  SELF
  HALF  // 180 graus
  FULL  // 360 graus
}

enum ReviewCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AssignmentStatus {
  PENDING
  DONE
}

enum FeedbackType {
  PRAISE
  CONSTRUCTIVE
  REQUEST
}

enum FeedbackVisibility {
  PUBLIC
  PRIVATE
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at")

  users        User[]
  departments  Department[]
  reviewCycles ReviewCycle[]
  feedbacks    Feedback[]

  @@map("companies")
}

model Department {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  users   User[]

  @@unique([companyId, name])
  @@map("departments")
}

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  authId       String   @unique @map("auth_id")
  email        String
  name         String
  role         Role     @default(EMPLOYEE)
  departmentId String?  @map("department_id")
  jobTitle     String?  @map("job_title")
  avatarUrl    String?  @map("avatar_url")
  managerId    String?  @map("manager_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  manager      User?       @relation("UserManager", fields: [managerId], references: [id])
  subordinates User[]      @relation("UserManager")

  evaluationsGiven    ReviewAssignment[] @relation("Evaluator")
  evaluationsReceived ReviewAssignment[] @relation("Evaluatee")

  feedbacksSent     Feedback[] @relation("FeedbackFrom")
  feedbacksReceived Feedback[] @relation("FeedbackTo")

  @@unique([companyId, email])
  @@map("users")
}

model ReviewCycle {
  id        String            @id @default(uuid())
  companyId String            @map("company_id")
  name      String
  type      ReviewCycleType
  startDate DateTime          @map("start_date")
  endDate   DateTime          @map("end_date")
  status    ReviewCycleStatus @default(DRAFT)
  createdAt DateTime          @default(now()) @map("created_at")

  company     Company            @relation(fields: [companyId], references: [id])
  criteria    ReviewCriteria[]
  assignments ReviewAssignment[]

  @@map("review_cycles")
}

model ReviewCriteria {
  id          String @id @default(uuid())
  cycleId     String @map("cycle_id")
  name        String
  description String @default("")
  weight      Float  @default(1.0)

  cycle   ReviewCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  answers ReviewAnswer[]

  @@map("review_criteria")
}

model ReviewAssignment {
  id          String           @id @default(uuid())
  cycleId     String           @map("cycle_id")
  evaluatorId String           @map("evaluator_id")
  evaluateeId String           @map("evaluatee_id")
  status      AssignmentStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")

  cycle     ReviewCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  evaluator User           @relation("Evaluator", fields: [evaluatorId], references: [id])
  evaluatee User           @relation("Evaluatee", fields: [evaluateeId], references: [id])
  answers   ReviewAnswer[]

  @@unique([cycleId, evaluatorId, evaluateeId])
  @@map("review_assignments")
}

model ReviewAnswer {
  id           String  @id @default(uuid())
  assignmentId String  @map("assignment_id")
  criteriaId   String  @map("criteria_id")
  score        Int?
  comment      String  @default("")

  assignment ReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  criteria   ReviewCriteria   @relation(fields: [criteriaId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, criteriaId])
  @@map("review_answers")
}

model Feedback {
  id         String             @id @default(uuid())
  companyId  String             @map("company_id")
  fromUserId String             @map("from_user_id")
  toUserId   String             @map("to_user_id")
  type       FeedbackType
  content    String
  visibility FeedbackVisibility @default(PRIVATE)
  createdAt  DateTime           @default(now()) @map("created_at")

  company  Company @relation(fields: [companyId], references: [id])
  fromUser User    @relation("FeedbackFrom", fields: [fromUserId], references: [id])
  toUser   User    @relation("FeedbackTo", fields: [toUserId], references: [id])

  @@map("feedbacks")
}
