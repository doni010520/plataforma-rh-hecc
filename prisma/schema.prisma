// ========== FASE 19: GAMIFICACAO ==========

enum BadgeCategory {
  ENGAGEMENT
  PERFORMANCE
  LEARNING
  COLLABORATION
  MILESTONE
}

model GamificationPoints {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  userId     String   @map("user_id")
  points     Int      @default(0)
  reason     String
  sourceType String   @default("") @map("source_type")
  sourceId   String?  @map("source_id")
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation("UserPoints", fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@map("gamification_points")
}

model Badge {
  id             String        @id @default(uuid())
  companyId      String        @map("company_id")
  name           String
  description    String        @default("")
  icon           String        @default("star")
  category       BadgeCategory @default(ENGAGEMENT)
  pointsRequired Int           @default(0) @map("points_required")
  criteria       String        @default("")
  createdAt      DateTime      @default(now()) @map("created_at")

  company    Company     @relation(fields: [companyId], references: [id])
  userBadges UserBadge[]

  @@index([companyId])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  awardedAt DateTime @default(now()) @map("awarded_at")
  awardedBy String?  @map("awarded_by")

  user  User  @relation("UserBadges", fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}
